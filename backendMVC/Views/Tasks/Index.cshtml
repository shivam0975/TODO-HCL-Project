@model List<TaskViewModel>
@{
    ViewData["Title"] = "My Tasks";
    Layout = "_Layout";
    var pending   = Model.Count(t => t.Status == "Pending");
    var completed = Model.Count(t => t.Status == "Completed");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-list-task me-2 text-primary"></i>My Tasks
        </h4>
        <small class="text-muted">Server-rendered via Razor View (.NET MVC)</small>
    </div>
    <a href="/Tasks/Logout" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
    </a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-1"></i> @success
    </div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i> @error
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i>Create New Task</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Title</label>
                <input type="text" name="title" class="form-control" maxlength="200" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Category</label>
                <input type="text" name="category" class="form-control" maxlength="100" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Priority</label>
                <select name="priority" class="form-select">
                    <option value="Low">Low</option>
                    <option value="Medium" selected>Medium</option>
                    <option value="High">High</option>
                </select>
            </div>
            <div class="col-md-8">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="2" maxlength="1000"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">Due Date</label>
                <input type="date" name="dueDate" class="form-control" />
            </div>
            <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Create Task
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-primary">@Model.Count</div>
            <div class="text-muted small">Total Tasks</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-warning">@pending</div>
            <div class="text-muted small">Pending</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-success">@completed</div>
            <div class="text-muted small">Completed</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted"></i>
        <p class="mt-3 text-muted">No tasks yet. Use the Angular app to create tasks.</p>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Category</th>
                            <th>Due Date</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr class="task-card">
                                <td class="text-muted small">@task.Id</td>
                                <td class="fw-semibold">@task.Title</td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(task.Description)
                                        ? "—"
                                        : (task.Description.Length > 60
                                            ? task.Description[..60] + "…"
                                            : task.Description))
                                </td>
                                <td>
                                    @if (task.Status == "Completed")
                                    {
                                        <span class="badge badge-completed rounded-pill">
                                            <i class="bi bi-check-circle me-1"></i>Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-pending rounded-pill">
                                            <i class="bi bi-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                                <td class="text-muted small">@task.Priority</td>
                                <td class="text-muted small">@(string.IsNullOrWhiteSpace(task.Category) ? "-" : task.Category)</td>
                                <td class="text-muted small">
                                    @(task.DueDate.HasValue
                                        ? task.DueDate.Value.ToString("dd MMM yyyy")
                                        : "—")
                                </td>
                                <td class="text-muted small">
                                    @task.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@task.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this task?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <p class="text-muted small mt-3 text-end">
        <i class="bi bi-info-circle me-1"></i>
        This page is server-side rendered by .NET MVC (Razor View).
    </p>
}
