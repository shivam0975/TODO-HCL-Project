@model TaskViewModel
@{
    ViewData["Title"] = "Edit Task";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Task
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Tasks
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i> @ViewBag.Error
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" class="row g-3">
            <input asp-for="Id" type="hidden" />

            <div class="col-md-6">
                <label asp-for="Title" class="form-label">Title</label>
                <input asp-for="Title" class="form-control" maxlength="200" required />
            </div>

            <div class="col-md-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="Pending">Pending</option>
                    <option value="Completed">Completed</option>
                </select>
            </div>

            <div class="col-md-3">
                <label asp-for="Priority" class="form-label">Priority</label>
                <select asp-for="Priority" class="form-select">
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                </select>
            </div>

            <div class="col-md-6">
                <label asp-for="Category" class="form-label">Category</label>
                <input asp-for="Category" class="form-control" maxlength="100" />
            </div>

            <div class="col-md-6">
                <label asp-for="DueDate" class="form-label">Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" maxlength="1000"></textarea>
            </div>

            <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
